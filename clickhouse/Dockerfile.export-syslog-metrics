# ClickHouse → Prometheus exporter (queries default.syslog, exposes :9099/metrics)
# Pinned index digest (docker buildx imagetools inspect python:3.12-slim)
FROM python:3.14-slim@sha256:584e89d31009a79ae4d9e3ab2fba078524a6c0921cb2711d05e8bb5f628fc9b9
WORKDIR /app
COPY requirements-export.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
COPY export-syslog-metrics.py .
EXPOSE 9099
CMD ["python", "export-syslog-metrics.py"]
